# Variables de entorno para el frontend
# Copia este archivo como .env y configura los valores según tu entorno

# URL de la API del backend
VITE_API_URL=http://localhost:8000

# Número de WhatsApp para atención al cliente
VITE_WHATSAPP_NUMBER=+573044931438

# Configuración de caché (opcional)
VITE_CACHE_TTL=7200000  # 2 horas en milisegundos

# Configuración de desarrollo
VITE_DEV_MODE=true 

# Variables de entorno en Vercel
# VITE_API_URL=https://tu-backend.onrender.com
# VITE_WHATSAPP_NUMBER=+573044931438
# VITE_CACHE_TTL=7200000
# VITE_DEV_MODE=false