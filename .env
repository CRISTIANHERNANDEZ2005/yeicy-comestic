# Ejemplo de configuración para desarrollo local y producción
# Copia este archivo como .env y ajusta según el entorno

# Para desarrollo local (Django corriendo en localhost:8000)
VITE_API_URL=http://127.0.0.1:8000/api

# Para producción (ajusta al dominio real de tu backend)
# VITE_API_URL=https://tu-dominio.com/api
